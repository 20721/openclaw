[Unit]
Description=小米音箱通知服务
After=network.target docker.service
Wants=docker.service

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/.openclaw/workspace/tools/xiaomi-notify
ExecStart=/usr/bin/python3 /home/ubuntu/.openclaw/workspace/tools/xiaomi-notify/xiaomi_notify.py --port 9090
Restart=always
RestartSec=5
StandardOutput=append:/home/ubuntu/.openclaw/workspace/tools/xiaomi-notify/xiaomi_notify.log
StandardError=append:/home/ubuntu/.openclaw/workspace/tools/xiaomi-notify/xiaomi_notify.log

# 环境变量
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
